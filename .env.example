# Supabase PostgreSQL
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL=""

# Cloudflare R2 (image storage + delivery)
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET="trip-photos"
# Public base URL of the bucket — its r2.dev domain or a custom domain.
# No trailing slash. NEXT_PUBLIC_ so the image loader can read it in the browser.
NEXT_PUBLIC_R2_PUBLIC_URL="https://images.example.com"

# Local directory of original images for `npm run images:process`.
# Optional — defaults to ./source-images. Layout mirrors the bucket:
#   trip-photos/{tripId}/{cover|photos}/*.{jpg,png,webp}
IMAGE_SOURCE_DIR="./source-images"
